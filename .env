#
# On a VPS, you can instead export these as real environment variables
# (e.g. via a systemd EnvironmentFile) -- see README.md.

# --- Telegram / Pyrogram (required) ---
API_ID=32947515
API_HASH=cc73af06049861e86e404ddd1fc6da35
BOT_TOKEN=8623020985:AAH75F8ub3oJYdCMPYji-QeQM0OhqBUy4Ks

# --- MongoDB (required) ---
MONGO_DB_URI=mongodb+srv://Payal:Aloksingh@payal.jv2kwch.mongodb.net/?appName=Payal
DB_NAME=mdb

# --- Logging / ownership (required) ---
# Numeric Telegram channel id (e.g. -1001234567890) or a public @username
# the bot account can post to.
LOG_CHANNEL=-1004441544932
# Telegram user id of the bot owner/admin.
OWNER_ID=7778005218

# --- Optional ---
# Space-separated list of image URLs shown on /start.
START_PIC=8623020985:AAH75F8ub3oJYdCMPYji-QeQM0OhqBUy4Ks

# Where downloaded episodes are staged before upload.
DOWNLOAD_DIR=./downloads

# Download queue limits
MAX_CONCURRENT_DOWNLOADS=2
MAX_DOWNLOADS_PER_USER=1
MAX_QUEUE_SIZE=50

# Download safety limits
MAX_DOWNLOAD_SIZE_MB=1900
REQUEST_TIMEOUT_SECONDS=30
MIN_FREE_DISK_MB=2500

# How long (seconds) search/episode/download-button sessions stay valid.
SESSION_TTL_SECONDS=3600

# When true, uploaded episodes are copied in full to LOG_CHANNEL. When
# false, only short metadata is logged there.
COPY_UPLOADS_TO_LOG_CHANNEL=true
